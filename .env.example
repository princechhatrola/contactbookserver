PORT=3001
MONGODB_URI=mongodb://localhost:27017/contactflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
EMAIL_CREDENTIALS_ENCRYPTION_KEY=your_email_credentials_encryption_key_here

# Datadog Integration (Optional)
DD_API_KEY=your_datadog_api_key_here
DD_SITE=us5.datadoghq.com
DD_SERVICE=smart-llm-backend
DD_ENV=development
DD_VERSION=1.0.0
DD_LOGS_ENABLED=false

# Tracking URL Base Configuration (e.g. https://your-domain.com/api/v1 in production)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name_here
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# LLM AI HTML Generator Configuration
LLM_API_KEY=your_llm_api_key_here
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini



